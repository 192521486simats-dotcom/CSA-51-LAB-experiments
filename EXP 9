#include <stdio.h>
#include <string.h>
#include <ctype.h>

// Playfair matrix (standard example key)
char matrix[5][5] = {
    {'P','L','A','Y','F'},
    {'I','R','E','X','M'},
    {'B','C','D','G','H'},
    {'K','N','O','Q','S'},
    {'T','U','V','W','Z'}
};

// Find position of character
void findPos(char ch, int *r, int *c) {
    if (ch == 'J') ch = 'I';

    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 5; j++) {
            if (matrix[i][j] == ch) {
                *r = i;
                *c = j;
                return;
            }
        }
    }
}

// Decrypt a pair
void decryptPair(char a, char b) {
    int r1, c1, r2, c2;

    findPos(a, &r1, &c1);
    findPos(b, &r2, &c2);

    if (r1 == r2) {
        // same row → move left
        printf("%c%c",
               matrix[r1][(c1 + 4) % 5],
               matrix[r2][(c2 + 4) % 5]);
    }
    else if (c1 == c2) {
        // same column → move up
        printf("%c%c",
               matrix[(r1 + 4) % 5][c1],
               matrix[(r2 + 4) % 5][c2]);
    }
    else {
        // rectangle
        printf("%c%c",
               matrix[r1][c2],
               matrix[r2][c1]);
    }
}

int main() {
    char text[] =
    "KXJEYUREBEZWEHEWRYTUHEYFSKREHEGOYFIWTTTUOLKSYCAJPO"
    "BOTEIZONTXBYBNTGONEYCUZWRGDSONSXBOUYWRHEBAAHYUSEDQ";

    int len = strlen(text);

    printf("Decrypted Text:\n");

    for (int i = 0; i < len; i += 2) {
        decryptPair(text[i], text[i + 1]);
    }

    return 0;
}
