#include <stdio.h>
#include <ctype.h>

int main() {
    char text[200];

    // Correct mapping
    char cipher[26] = {
        'C','I','P','H','E','R','A','B','D','F','G','J',
        'K','L','M','N','O','Q','S','T','U','V','W','X','Y','Z'
    };

    printf("Enter plaintext: ");
    fgets(text, sizeof(text), stdin);

    printf("Ciphertext: ");

    for (int i = 0; text[i] != '\0'; i++) {

        if (text[i] >= 'a' && text[i] <= 'z') {
            printf("%c", tolower(cipher[text[i] - 'a']));
        }
        else if (text[i] >= 'A' && text[i] <= 'Z') {
            printf("%c", cipher[text[i] - 'A']);
        }
        else {
            printf("%c", text[i]); // space, punctuation
        }
    }

    return 0;
}
