#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char text[100];
    int key;

    printf("Enter the plain text: ");
    fgets(text, sizeof(text), stdin);

    printf("Enter the key (1-25): ");
    scanf("%d", &key);

    printf("Encrypted text: ");

    for (int i = 0; text[i] != '\0'; i++) {
        char ch = text[i];

        if (isupper(ch))
            ch = ((ch - 'A' + key) % 26) + 'A';
        else if (islower(ch))
            ch = ((ch - 'a' + key) % 26) + 'a';

        printf("%c", ch);
    }

    return 0;
}
