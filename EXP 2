#include <stdio.h>
#include <ctype.h>
#include <string.h>

int main()
{
    char plaintext[100];
    char ciphertext[100];

    // Plain alphabet and substitution alphabet
    char plain[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    char cipher[] = "QWERTYUIOPASDFGHJKLZXCVBNM";

    printf("Enter the plaintext: ");
    fgets(plaintext, sizeof(plaintext), stdin);

    printf("Encrypted text: ");

    for (int i = 0; plaintext[i] != '\0'; i++)
    {
        char ch = plaintext[i];

        if (isupper(ch))
        {
            for (int j = 0; j < 26; j++)
            {
                if (ch == plain[j])
                {
                    printf("%c", cipher[j]);
                    break;
                }
            }
        }
        else if (islower(ch))
        {
            ch = toupper(ch);

            for (int j = 0; j < 26; j++)
            {
                if (ch == plain[j])
                {
                    printf("%c", tolower(cipher[j]));
                    break;
                }
            }
        }
        else
        {
            printf("%c", ch);   // Keep spaces and symbols unchanged
        }
    }

    return 0;
}
